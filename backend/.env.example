# ─────────────────────────────────────────────────────────────────────────────
#  RAG Chatbot 백엔드 환경변수.
#  복사해서 사용:  cp .env.example .env  →  아래 [필수] 항목 채우기
# ─────────────────────────────────────────────────────────────────────────────

# ───────── [필수] LLM 프로바이더 선택 ─────────
# 테스트용 퍼블릭 OpenAI:  openai
# 운영(사내 게이트웨이):    azure
LLM_PROVIDER=openai

# ───────── [필수] 퍼블릭 OpenAI (LLM_PROVIDER=openai 일 때) ─────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OpenAI 호환 엔드포인트(예: 사내 프록시) 사용 시에만 지정:
# OPENAI_BASE_URL=https://my-proxy.local/v1
OPENAI_BASE_URL=

# ───────── [필수] Elasticsearch 클러스터 ─────────
# 단일 노드:   ES_HOSTS=https://es01.mycorp.io:9200
# 다중 노드:   ES_HOSTS=https://es01.mycorp.io:9200,https://es02.mycorp.io:9200
ES_HOSTS=https://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=

# 자체 서명 인증서면 false 그대로. 사내 CA 번들이 있으면 ES_CA_CERTS에 경로 + ES_VERIFY_CERTS=true
ES_VERIFY_CERTS=false
ES_CA_CERTS=

# ───────── 사내 LLM (LLM_PROVIDER=azure 일 때) ─────────
# 운영 시점에 채워주세요. 지금은 테스트라 비워둬도 무방.
HCHAT_API_KEY=
HCHAT_ENDPOINT=https://internal-apigw-kr.hmg-corp.io/hchat-in/api/v3
HCHAT_DEPLOYMENT=gpt-5.4-mini
HCHAT_API_VERSION=2024-02-01

# ───────── [선택] 인덱스명 / 필드명 ─────────
ES_INDEX_ELASTICSEARCH=elasticsearch_docs
ES_INDEX_KAFKA=kafka_docs
ES_FIELD_TITLE=title
ES_FIELD_CONTENT=content
ES_FIELD_SEMANTIC=content_semantic
ES_FIELD_URL=url

# ───────── [선택] 검색 / 대화 파라미터 ─────────
RETRIEVAL_RANK_WINDOW=50
RETRIEVAL_RANK_CONSTANT=60
RETRIEVAL_TOP_K=10
RETRIEVAL_MAX_RETRY=2
MAX_HISTORY_TURNS=5

# ───────── [선택] 서버 ─────────
BACKEND_PORT=8000
LOG_LEVEL=INFO
